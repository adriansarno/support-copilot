# GCP
GCP_PROJECT=your-gcp-project
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# BigQuery
BQ_DATASET=support_copilot
BQ_CHUNKS_TABLE=chunks
BQ_FEEDBACK_TABLE=feedback
BQ_CHATS_TABLE=chats

# GCS
GCS_BUCKET=support-copilot-artifacts

# Vertex Vector Search
VERTEX_INDEX_ID=
VERTEX_INDEX_ENDPOINT_ID=

# LLM Provider: openai | gemini | deepseek
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash-001

# Embedding Provider: vertex | openai
EMBEDDING_PROVIDER=vertex
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=256

# OpenAI (if using)
OPENAI_API_KEY=

# DeepSeek (if using)
DEEPSEEK_API_KEY=

# W&B
WANDB_API_KEY=
WANDB_PROJECT=support-copilot

# App version (from VERSION file; used at build time for Docker)
APP_VERSION=0.1.0

# API
API_KEY=change-me-in-production
JWT_SECRET=change-me-in-production

# Prompt version
PROMPT_VERSION=v1
